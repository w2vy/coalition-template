# ─────────────────────────────────────────────────────────────────────────────
# config.env — YOUR non-secret provider configuration.
#
# This file is COMMITTED to the repo and is PUBLIC. Only non-secret values go
# here. Fill in each value below, then commit.
#
# SECRETS DO NOT GO HERE. Set these ONCE in the Flux encrypted deployment
# environment at deploy time (see README → "Where secrets live"):
#   COALITION_KEY  STRIPE_SECRET_KEY  STRIPE_WEBHOOK_SECRET  AGENT_KEY  SESSION_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# Your provider slug — must match the slug MoltenTech assigned you.
PROVIDER_SLUG=your-slug

# MoltenTech API base URL (leave as-is for production).
MT_BASE_URL=https://moltentech.us

# MoltenTech's public key (base64). Copy from https://moltentech.us/api/mt-pubkey
MT_PUBKEY=

# Your owner Flux / ZelID address — this authorizes console actions and the
# console wallet-login. Use the PUBLIC address only. NEVER a private key.
OWNER_ADDRESS=

# Your price per tier, in cents. Must match the tiers in your signed manifest.
TIER_PRICES_JSON={"nimbus":2200}

# Console session lifetime (hours) and listen port. Leave as-is unless you
# have a reason to change them.
SESSION_TTL_HOURS=24
PORT=8088
