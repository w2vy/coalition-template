# ─────────────────────────────────────────────────────────────────────────────
# config.env — the ONE file you edit. Non-secret; committed to the repo (PUBLIC).
#
# This single file drives BOTH your runtime coalition config AND your signed
# manifest — you never edit the manifest by hand. Fill in the values, then:
#   • run the sign step (tools/sign-manifest.md) to (re)generate manifest.json
#   • commit config.env + manifest.json
#
# SECRETS DO NOT GO HERE. Set these ONCE in the Flux encrypted deployment
# environment (see README → "Where secrets live"):
#   COALITION_KEY  STRIPE_SECRET_KEY  STRIPE_WEBHOOK_SECRET  AGENT_KEY  SESSION_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# ── Identity (also shown on your marketplace card) ──
PROVIDER_SLUG=your-slug
PROVIDER_NAME=Your Operator Name
PROVIDER_LOCATION=City, Country
PROVIDER_DESCRIPTION=Short description shown on the marketplace card.
PROVIDER_CONTACT=ops@example.com

# Your owner Flux / ZelID address — authorizes console actions + wallet login.
# PUBLIC address only. NEVER a private key.
OWNER_ADDRESS=

# ── MoltenTech connection ──
MT_BASE_URL=https://moltentech.us
# MoltenTech's public key (base64), from https://moltentech.us/api/mt-pubkey
MT_PUBKEY=

# ── Your coalition's public URL (your Flux app domain) ──
COALITION_URL=https://your-app.app.runonflux.io

# ── Tiers you offer — defined ONCE here. Drives your signed manifest
#    (tier, capacity, storagePool) AND your prices (priceCents). ──
TIERS_JSON=[{"tier":"nimbus","capacity":8,"storagePool":"local-lvm","priceCents":2200}]

# ── Policy ──
TRIAL_DAYS=1
MANUAL_APPROVAL=false

# ── Console ──
SESSION_TTL_HOURS=24
PORT=8088
